---
import BaseLayout from '../layouts/BaseLayout.astro';
import TodaysEortologio from '../components/TodaysEortologio.astro';
import NewsWidget from '../components/NewsWidget.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Naos-* tagged articles live under /naos-kai-latreia/<section>/ (vestments,
// orders, architecture). They're real articles — included in the daily-reading
// rotation but labeled "Ναὸς & Λατρεία" so the homepage card reflects the
// section the entry truly belongs to.
const isNaosEntry = (tags?: readonly string[]) =>
  !!tags && tags.some(t => t.startsWith('naos-'));

// Liturgical type partitions — must stay in lockstep with /ymnoi/index.astro
// (hymn family) and /proseuxitari/index.astro (prayer). Other liturgical
// types (apodeipno, paraklesis, chairetismoi, akathistos, theia-metalipsi,
// akolouthia) live under /akolouthies/ and are NOT in the rotation.
const HYMN_TYPES = ['hymn', 'tropar', 'kontak', 'ode'] as const;
const PRAYER_TYPES = ['prayer'] as const;

// Effective "featured day" in Europe/Athens with rollover at 06:00 local.
// Before 06:00 Athens we still show the previous day's pick; at 06:00 it advances.
const athensParts = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'Europe/Athens',
  year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit',
  hour12: false,
}).formatToParts(new Date());
let effY = Number(athensParts.find(p => p.type === 'year')!.value);
let effM = Number(athensParts.find(p => p.type === 'month')!.value);
let effD = Number(athensParts.find(p => p.type === 'day')!.value);
const effH = Number(athensParts.find(p => p.type === 'hour')!.value);
if (effH < 6) {
  const prev = new Date(Date.UTC(effY, effM - 1, effD) - 86_400_000);
  effY = prev.getUTCFullYear();
  effM = prev.getUTCMonth() + 1;
  effD = prev.getUTCDate();
}
const todayKey =
  String(effM).padStart(2, '0') + '-' +
  String(effD).padStart(2, '0');

type FeaturedItem = {
  href: string;
  title: string;
  description: string;
  kindLabel: string;
};

const [articlesAll, erminiesAll, saintsAll, fathersAll, liturgicalAll] = await Promise.all([
  getCollection('articles'),
  getCollection('erminies'),
  getCollection('saints'),
  getCollection('fathers'),
  getCollection('liturgical'),
]);

// Pool composition — one feed per user-facing section the homepage card
// can deep-link into. Sections covered:
//   /didaskalia/         → articles (non-naos)         label "Ἄρθρο"
//   /naos-kai-latreia/   → articles (naos-* tagged)    label "Ναὸς & Λατρεία"
//   /bible/erminies/     → erminies                    label "Ἑρμηνεία"
//   /prosopa/ (saints)   → saints (excl. today)        label "Βίος Ἁγίου"
//   /prosopa/ (fathers)  → fathers                     label "Πατὴρ τῆς Ἐκκλησίας"
//   /proseuxitari/       → liturgical type=prayer      label "Προσευχή"
//   /ymnoi/              → liturgical hymn family      label "Ὕμνος"
const pool: FeaturedItem[] = [
  ...articlesAll
    .filter(a => a.data.language === lang && !a.data.draft && !isNaosEntry(a.data.tags))
    .map(a => ({
      href: `/articles/${a.id}/`,
      title: a.data.title,
      description: a.data.description,
      kindLabel: 'Ἄρθρο',
    })),
  ...articlesAll
    .filter(a => a.data.language === lang && !a.data.draft && isNaosEntry(a.data.tags))
    .map(a => ({
      href: `/articles/${a.id}/`,
      title: a.data.title,
      description: a.data.description,
      kindLabel: 'Ναὸς & Λατρεία',
    })),
  ...erminiesAll
    .filter(e => e.data.language === lang && !e.data.draft)
    .map(e => ({
      href: `/bible/erminies/${e.id}/`,
      title: e.data.title,
      description: e.data.description,
      kindLabel: 'Ἑρμηνεία',
    })),
  ...saintsAll
    .filter(s => s.data.language === lang && !s.data.draft && s.data.feastDay !== todayKey)
    .map(s => ({
      href: `/saints/${s.id}/`,
      title: s.data.name,
      description: s.data.life,
      kindLabel: 'Βίος Ἁγίου',
    })),
  ...fathersAll
    .filter(f => f.data.language === lang && !f.data.draft)
    .map(f => ({
      href: `/fathers/${f.id}/`,
      title: f.data.fullName,
      description: f.data.summary,
      kindLabel: 'Πατὴρ τῆς Ἐκκλησίας',
    })),
  ...liturgicalAll
    .filter(l => l.data.language === lang && (PRAYER_TYPES as readonly string[]).includes(l.data.type))
    .map(l => ({
      href: `/liturgical/${l.id}/`,
      title: l.data.title,
      description: '',
      kindLabel: 'Προσευχή',
    })),
  ...liturgicalAll
    .filter(l => l.data.language === lang && (HYMN_TYPES as readonly string[]).includes(l.data.type))
    .map(l => ({
      href: `/liturgical/${l.id}/`,
      title: l.data.title,
      description: '',
      kindLabel: 'Ὕμνος',
    })),
];

// Deterministic daily pick keyed to the Athens "featured day" computed above:
// rotates once per Athens day with rollover at 06:00 local; same pick on every
// build that ships between two rollovers.
const seed = effY * 10000 + effM * 100 + effD;
const featured = pool.length > 0 ? pool[seed % pool.length] : null;
---

<BaseLayout title={t('site.title')}>
  <section class="hero">
    <h1>{t('site.title')}</h1>
    <p class="tagline">{t('site.tagline')}</p>
  </section>

  <TodaysEortologio />

  <NewsWidget limit={5} />

  {featured && (
    <section class="featured">
      <h2>Προτεινόμενο Ἀνάγνωσμα τῆς Ἡμέρας</h2>
      <a class="featured-card" href={featured.href}>
        <span class="featured-kind">{featured.kindLabel}</span>
        <h3>{featured.title}</h3>
        {featured.description && <p class="muted">{featured.description}</p>}
        <span class="featured-cta">Διαβάστε περισσότερα →</span>
      </a>
    </section>
  )}
</BaseLayout>

<style>
  .featured {
    margin-top: 2.5rem;
  }
  .featured h2 {
    margin: 0 0 1rem;
    font-size: 1.4rem;
  }
  .featured-card {
    display: block;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
    background: var(--color-surface, #faf7f1);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .featured-card:hover,
  .featured-card:focus-visible {
    border-color: var(--color-accent);
    outline: none;
  }
  .featured-kind {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
  }
  .featured-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    color: var(--color-text);
  }
  .featured-card p {
    margin: 0 0 0.85rem;
    line-height: 1.55;
  }
  .featured-cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
