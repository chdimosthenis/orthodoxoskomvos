---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import TodaysSaint from '../components/TodaysSaint.astro';
import NewsWidget from '../components/NewsWidget.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Naos-* tagged articles are subsection entries (vestments, orders,
// architecture), not standalone articles — exclude from "recent articles".
const isNaosEntry = (tags?: readonly string[]) =>
  !!tags && tags.some(t => t.startsWith('naos-'));

const articles = (await getCollection('articles'))
  .filter(a => a.data.language === lang && !a.data.draft)
  .filter(a => !isNaosEntry(a.data.tags))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title={t('site.title')}>
  <section class="hero">
    <h1>{t('site.title')}</h1>
    <p class="tagline">{t('site.tagline')}</p>
  </section>

  <TodaysSaint />

  <NewsWidget limit={5} />

  <section class="section">
    <h2>{t('latest.articles')}</h2>
    <ul class="card-list">
      {articles.length === 0 ? (
        <li class="muted">{t('no.entries')}</li>
      ) : articles.map(a => (
        <li>
          <ArticleCard
            slug={a.id}
            title={a.data.title}
            description={a.data.description}
            pubDate={a.data.pubDate}
            language={a.data.language}
          />
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
