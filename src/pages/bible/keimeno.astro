---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const books = (await getCollection('bible'))
  .filter(b => b.data.language === lang)
  .sort((a, b) => a.data.order - b.data.order);

const sections = [
  { id: 'gospels',     title: t('bible.section.gospels'),    div: 'gospel' },
  { id: 'acts',        title: t('bible.section.acts'),       div: 'acts' },
  { id: 'paul',        title: t('bible.section.paul'),       div: 'paul' },
  { id: 'general',     title: t('bible.section.general'),    div: 'general' },
  { id: 'revelation',  title: t('bible.section.revelation'), div: 'revelation' },
] as const;
---

<BaseLayout title="Πλῆρες Κείμενο — Καινὴ Διαθήκη">
  <p class="back-link"><a href="/bible">← Καινὴ Διαθήκη</a></p>
  <h1>Πλῆρες Κείμενο</h1>
  <p class="muted">{t('bible.intro')}</p>

  {books.length === 0 ? (
    <p class="muted">{t('no.entries')}</p>
  ) : sections.map(section => {
    const inSection = books.filter(b => b.data.division === section.div);
    if (inSection.length === 0) return null;
    return (
      <section class="bible-section" id={section.id}>
        <h2>{section.title}</h2>
        <ul class="bible-list">
          {inSection.map(b => (
            <li class="bible-card">
              <a href={getLocalizedPath(`/bible/${b.id}`, lang)} lang={b.data.language}>
                <span class="bible-order">{b.data.order}</span>
                <span class="bible-name">{b.data.book}</span>
                {b.data.chapters && (
                  <span class="bible-chapters">{b.data.chapters} {t('bible.chapters')}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</BaseLayout>

<style>
  .back-link { font-size: 0.9rem; margin-bottom: 1rem; }
  .bible-section { margin-top: 2.5rem; }
  .bible-section h2 {
    margin-top: 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .bible-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 0.5rem 1rem;
  }
  .bible-card a {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.6rem 0.5rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-border);
    border-radius: 2px;
    transition: background 0.15s ease;
  }
  .bible-card a:hover {
    background: var(--color-attribution-bg);
    color: var(--color-accent);
  }
  .bible-order {
    flex-shrink: 0;
    min-width: 1.6rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-muted);
    text-align: right;
  }
  .bible-name { flex: 1; font-size: 1.05rem; }
  .bible-chapters {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }
</style>
