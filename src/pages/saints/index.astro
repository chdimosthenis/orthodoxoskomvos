---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SaintCard from '../../components/SaintCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const saints = (await getCollection('saints'))
  .filter(s => s.data.language === lang)
  .sort((a, b) => a.data.feastDay.localeCompare(b.data.feastDay));
---

<BaseLayout title={t('all.saints')}>
  <h1>{t('all.saints')}</h1>
  <ul class="card-list">
    {saints.length === 0 ? (
      <li class="muted">{t('no.entries')}</li>
    ) : saints.map(s => (
      <li>
        <SaintCard
          slug={s.id}
          name={s.data.name}
          feastDay={s.data.feastDay}
          category={s.data.category}
          language={s.data.language}
          iconUrl={s.data.iconUrl}
        />
      </li>
    ))}
  </ul>
</BaseLayout>
