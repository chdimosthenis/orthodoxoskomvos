---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const today = new Date();
const todayKey =
  String(today.getMonth() + 1).padStart(2, '0') + '-' +
  String(today.getDate()).padStart(2, '0');

const allSaints = (await getCollection('saints'))
  .filter(s => s.data.language === lang && !s.data.draft);

const todays = allSaints.filter(s => s.data.feastDay === todayKey);

type SaintEntry = (typeof allSaints)[number];
type Upcoming = { entry: SaintEntry; daysUntil: number; dateStr: string };

const localeTag = lang === 'el' ? 'el-GR' : 'en-GB';

function buildUpcoming(): Upcoming[] {
  if (todays.length > 0) return [];
  const sorted = allSaints.slice().sort((a, b) => a.data.feastDay.localeCompare(b.data.feastDay));
  const after = sorted.filter(s => s.data.feastDay > todayKey);
  // If fewer than 3 feasts left this calendar year, wrap to start of next year
  const candidates = after.length >= 3 ? after : [...after, ...sorted];
  const seen = new Set<string>();
  const picked: SaintEntry[] = [];
  for (const s of candidates) {
    if (seen.has(s.id)) continue;
    seen.add(s.id);
    picked.push(s);
    if (picked.length === 3) break;
  }
  const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate());
  return picked.map(entry => {
    const [m, d] = entry.data.feastDay.split('-').map(Number);
    let target = new Date(today.getFullYear(), m - 1, d);
    if (target < todayStart) target = new Date(today.getFullYear() + 1, m - 1, d);
    const daysUntil = Math.round((target.getTime() - todayStart.getTime()) / 86_400_000);
    const dateStr = target.toLocaleDateString(localeTag, { day: 'numeric', month: 'long' });
    return { entry, daysUntil, dateStr };
  });
}

const upcoming = buildUpcoming();
const rtf = new Intl.RelativeTimeFormat(lang, { numeric: 'auto' });
const heading = todays.length > 0 ? t('today.saint') : t('today.upcoming');
---

<section class="todays-saint">
  <h2>{heading}</h2>
  {todays.length > 0 ? (
    <ul class="todays-list">
      {todays.map(s => (
        <li>
          {s.data.iconUrl && (
            <a class="todays-icon-link" href={getLocalizedPath(`/saints/${s.id}`, lang)} aria-hidden="true" tabindex="-1">
              <img class="todays-icon" src={s.data.iconUrl} alt="" loading="eager" decoding="async" />
            </a>
          )}
          <div class="todays-text">
            <h3>
              <a href={getLocalizedPath(`/saints/${s.id}`, lang)} lang={s.data.language}>{s.data.name}</a>
            </h3>
            <p class="muted" lang={s.data.language}>{s.data.life}</p>
            {s.data.tropar && (
              <blockquote class="todays-tropar polytonic" lang={s.data.language}>
                <span class="tropar-label">{t('tropar')}</span>
                {s.data.tropar}
              </blockquote>
            )}
          </div>
        </li>
      ))}
    </ul>
  ) : upcoming.length > 0 ? (
    <ul class="todays-list upcoming-list">
      {upcoming.map(u => (
        <li>
          {u.entry.data.iconUrl && (
            <a class="todays-icon-link" href={getLocalizedPath(`/saints/${u.entry.id}`, lang)} aria-hidden="true" tabindex="-1">
              <img class="todays-icon" src={u.entry.data.iconUrl} alt="" loading="lazy" decoding="async" />
            </a>
          )}
          <div class="todays-text">
            <h3>
              <a href={getLocalizedPath(`/saints/${u.entry.id}`, lang)} lang={u.entry.data.language}>{u.entry.data.name}</a>
            </h3>
            <p class="upcoming-meta">
              <time>{u.dateStr}</time>
              <span class="muted"> · {rtf.format(u.daysUntil, 'day')}</span>
            </p>
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <p class="muted">{t('today.none')}</p>
  )}
</section>

<style>
  .todays-saint {
    margin-top: 2rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold);
    border-radius: 0 4px 4px 0;
    background: var(--color-attribution-bg);
  }
  .todays-saint h2 {
    margin-top: 0;
    font-size: 1.4rem;
  }
  .todays-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }
  .todays-list li {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .todays-icon-link {
    flex-shrink: 0;
    border-bottom: none;
  }
  .todays-icon {
    display: block;
    width: 96px;
    height: 96px;
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  }
  .upcoming-list .todays-icon {
    width: 64px;
    height: 64px;
  }
  .todays-text { flex: 1; min-width: 0; }
  .todays-text h3 {
    margin: 0 0 0.35rem;
    font-size: 1.2rem;
  }
  .todays-text h3 a {
    color: var(--color-text);
    border-bottom: none;
  }
  .todays-text h3 a:hover {
    color: var(--color-accent);
  }
  .todays-text p {
    margin: 0;
  }
  .upcoming-meta {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }
  .upcoming-meta time {
    color: var(--color-text);
  }
  .todays-tropar {
    margin: 0.85rem 0 0;
    padding: 0.6rem 0 0.6rem 1rem;
    border-left: 2px solid var(--color-gold);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-text);
  }
  .todays-tropar .tropar-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    font-style: normal;
    margin-bottom: 0.3rem;
  }
</style>
