---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShareButtons from '../components/ShareButtons.astro';

const shareUrl = new URL(Astro.url.pathname, Astro.site).toString();

// --- 1. Ἁγιορείτικες Μονές (κατὰ τάξιν, 20) ---
const athos = [
  { rank: 1,  name: 'Μεγίστη Λαύρα',                       century: 'Ι΄ αἰών (963)',      patron: 'Ἅγιος Ἀθανάσιος ὁ Ἀθωνίτης' },
  { rank: 2,  name: 'Βατοπεδίου',                          century: 'Ι΄ αἰών',            patron: 'Εὐαγγελισμὸς τῆς Θεοτόκου' },
  { rank: 3,  name: 'Ἰβήρων',                              century: 'Ι΄ αἰών (980)',      patron: 'Κοίμησις τῆς Θεοτόκου · Παναγία Πορταΐτισσα' },
  { rank: 4,  name: 'Χιλανδαρίου',                         century: 'ΙΒ΄ αἰών (1198)',    patron: 'Εἰσόδια τῆς Θεοτόκου · σερβικὴ μονή' },
  { rank: 5,  name: 'Διονυσίου',                           century: 'ΙΔ΄ αἰών (1374)',    patron: 'Γενέθλιον τοῦ Τιμίου Προδρόμου' },
  { rank: 6,  name: 'Κουτλουμουσίου',                      century: 'ΙΓ΄ αἰών',           patron: 'Μεταμόρφωσις τοῦ Σωτῆρος' },
  { rank: 7,  name: 'Παντοκράτορος',                       century: 'ΙΔ΄ αἰών (1363)',    patron: 'Μεταμόρφωσις τοῦ Σωτῆρος' },
  { rank: 8,  name: 'Ξηροποτάμου',                         century: 'Ι΄ αἰών',            patron: 'Ἅγιοι Τεσσαράκοντα Μάρτυρες' },
  { rank: 9,  name: 'Ζωγράφου',                            century: 'Ι΄ αἰών',            patron: 'Ἅγιος Γεώργιος · βουλγαρικὴ μονή' },
  { rank: 10, name: 'Δοχειαρίου',                          century: 'Ι΄ αἰών',            patron: 'Ἀρχάγγελοι Μιχαὴλ καὶ Γαβριήλ · Παναγία Γοργοϋπήκοος' },
  { rank: 11, name: 'Καρακάλλου',                          century: 'ΙΑ΄ αἰών',           patron: 'Ἀπόστολοι Πέτρος καὶ Παῦλος' },
  { rank: 12, name: 'Φιλοθέου',                            century: 'Ι΄ αἰών',            patron: 'Εὐαγγελισμὸς τῆς Θεοτόκου' },
  { rank: 13, name: 'Σίμωνος Πέτρας',                      century: 'ΙΔ΄ αἰών',           patron: 'Γέννησις τοῦ Κυρίου' },
  { rank: 14, name: 'Ἁγίου Παύλου',                        century: 'Ι΄ αἰών',            patron: 'Ὑπαπαντὴ τοῦ Κυρίου' },
  { rank: 15, name: 'Σταυρονικήτα',                        century: 'ΙΣΤ΄ αἰών (1542)',   patron: 'Ἅγιος Νικόλαος' },
  { rank: 16, name: 'Ξενοφῶντος',                          century: 'Ι΄ αἰών',            patron: 'Ἅγιος Γεώργιος ὁ Τροπαιοφόρος' },
  { rank: 17, name: 'Γρηγορίου',                           century: 'ΙΔ΄ αἰών',           patron: 'Ἅγιος Νικόλαος' },
  { rank: 18, name: 'Ἐσφιγμένου',                          century: 'Ι΄ αἰών',            patron: 'Ἀνάληψις τοῦ Κυρίου' },
  { rank: 19, name: 'Ρωσικοῦ Ἁγίου Παντελεήμονος',         century: 'ΙΑ΄ αἰών',           patron: 'Ἅγιος Παντελεήμων · ρωσικὴ μονή' },
  { rank: 20, name: 'Κωνσταμονίτου',                       century: 'ΙΑ΄ αἰών',           patron: 'Ἅγιος Στέφανος ὁ Πρωτομάρτυς' },
