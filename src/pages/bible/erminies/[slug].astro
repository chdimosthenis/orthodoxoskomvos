---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('erminies');
  return entries
    .filter(e => e.data.language === 'el' && !e.data.draft)
    .map(e => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const shareUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImagePath = entry.data.image ?? '/og-default.png';

const topicLabel: Record<string, string> = {
  parable: 'Παραβολή',
  miracle: 'Θαῦμα',
  discourse: 'Ὁμιλία',
  narrative: 'Ἀφήγησις',
  epistle: 'Ἐπιστολικὸ χωρίο',
};

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  author: { '@type': 'Person', name: entry.data.author },
  inLanguage: entry.data.language,
  about: entry.data.reference,
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  jsonld={jsonld}
  ogImage={ogImagePath}
  ogType="article"
  articlePublished={entry.data.pubDate.toISOString()}
  articleModified={entry.data.updatedDate?.toISOString()}
  articleAuthor={entry.data.author}
>
  <p class="back-link"><a href="/bible/erminies">← Ἑρμηνεῖες</a></p>
  <article>
    <header class="erm-header">
      <p class="erm-meta">
        <span class="erm-topic">{topicLabel[entry.data.topic] ?? entry.data.topic}</span>
        {' · '}
        <span class="erm-ref">{entry.data.reference}</span>
      </p>
      <h1>{entry.data.title}</h1>
    </header>
    <div class="article-body">
      <Content />
    </div>
    <ShareButtons title={entry.data.title} url={shareUrl} />
  </article>
</BaseLayout>

<style>
  .back-link { font-size: 0.9rem; margin-bottom: 1rem; }
  .erm-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .erm-header h1 { margin-top: 0.4rem; }
  .erm-meta {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }
  .erm-topic { color: var(--color-accent); font-weight: 600; }
  .erm-ref { color: var(--color-gold); font-weight: 600; }
</style>
