// --- 5. Σινᾶ ---
const sina = [
  { name: 'Μονὴ Ἁγίας Αἰκατερίνης τοῦ Σινᾶ', location: 'Ὄρος Σινᾶ, Αἴγυπτος', century: 'ΣΤ΄ αἰών (548–565)', note: 'UNESCO. Ἱδρύθη ἐπὶ Ἰουστινιανοῦ. Αὐτόνομος Ἀρχιεπισκοπή. Ἡ ἀρχαιοτέρα συνεχῶς λειτουργοῦσα μονὴ τῆς χριστιανωσύνης. Σπίνθηρ τῆς Καιομένης Βάτου.' },
];
---

<BaseLayout title="Εὑρετήριο Ναῶν καὶ Μοναστηριῶν">
  <h1>Εὑρετήριο Ναῶν καὶ Μοναστηριῶν</h1>
  <p class="muted">
    Ἐπιλεκτικὸς —ὄχι ἐξαντλητικός— κατάλογος τῶν μεγαλυτέρων προσκυνημάτων
    τῆς Ὀρθοδοξίας: τὸ Ἅγιον Ὄρος, τὰ Μετέωρα, τὰ μεγάλα προσκυνήματα τῆς
    Ἑλλάδος, οἱ ἱστορικοὶ ναοὶ τῆς Ρωμηοσύνης καὶ ἡ θεοβάδιστος Μονὴ τοῦ Σινᾶ.
    Σκοπὸς τοῦ εὑρετηρίου εἶναι ἡ συνοπτικὴ τοπογραφικὴ καὶ ἱστορικὴ ἀναφορά,
    ὄχι ἡ πλήρης ἐνημέρωσις γιὰ ἕκαστον ἀπὸ τὰ ἑκατοντάδες ἀκόμη ἱερὰ μνημεῖα.
  </p>

  <section class="mn-section">
    <h2>Ἁγιορείτικες Μονές</h2>
    <p class="muted">
      Οἱ εἴκοσι κυρίαρχες μοναστικὲς μονὲς τοῦ Ἁγίου Ὄρους Ἄθω, παρατιθέμενες
      κατὰ τὴν παραδοσιακὴ ἱεραρχικὴ τάξιν. Ἕκαστη μονὴ ἀνήκει στὴν Ἱερὰ
      Κοινότητα τοῦ Ἁγίου Ὄρους καὶ ὑπάγεται κανονικῶς στὸ Οἰκουμενικὸν Πατριαρχεῖον.
    </p>
    <table class="mn-table">
      <thead><tr><th>Τάξις</th><th>Ὄνομα</th><th>Αἰὼν ἱδρύσεως</th><th>Πανηγυρίζει</th></tr></thead>
      <tbody>
        {athos.map(m => (
          <tr class="mn-row">
            <td class="mn-rank">{m.rank}</td>
            <td class="mn-title">{m.name}</td>
            <td class="mn-date">{m.century}</td>
            <td class="muted">{m.patron}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mn-section">
    <h2>Μετέωρα</h2>
    <p class="muted">
      Συγκρότημα μονῶν ἐπὶ μεγαλιθικῶν βραχωδῶν λοφίσκων στὴν θεσσαλικὴ
      πεδιάδα, παρὰ τὴν Καλαμπάκα. Ὁ μοναχισμὸς ἐνεφανίσθη ἤδη ἀπὸ τὸν ΙΑ΄ αἰ.
      ὡς ἀσκητική, καὶ ὀργανώθη σὲ μονὲς τὸν ΙΔ΄ αἰ. Σήμερον λειτουργοῦν ἕξι.
    </p>
    <table class="mn-table">
      <thead><tr><th>Ὄνομα</th><th>Αἰὼν ἱδρύσεως</th><th>Πανηγυρίζει</th><th>Σημείωσις</th></tr></thead>
      <tbody>
        {meteora.map(m => (
          <tr class="mn-row">
            <td class="mn-title">{m.name}</td>
            <td class="mn-date">{m.century}</td>
            <td class="mn-date">{m.patron}</td>
            <td class="muted">{m.note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mn-section">
    <h2>Μεγάλα προσκυνήματα τῆς Ἑλλάδος</h2>
    <p class="muted">
      Πανελλήνια καὶ διεθνῆ προσκυνήματα: μονὲς καὶ ναοὶ μὲ θαυματουργὲς
      εἰκόνες, ἱερὰ λείψανα, ἢ διακριτὴ ἱστορικὴ καὶ πνευματικὴ σημασία.
    </p>
    <table class="mn-table">
      <thead><tr><th>Ὄνομα</th><th>Τοποθεσία</th><th>Αἰὼν ἱδρύσεως</th><th>Σημείωσις</th></tr></thead>
      <tbody>
        {proskynemata.map(p => (
          <tr class="mn-row">
            <td class="mn-title">{p.name}</td>
            <td class="mn-date">{p.location}</td>
            <td class="mn-date">{p.century}</td>
            <td class="muted">{p.note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mn-section">
    <h2>Ἱστορικοὶ ναοί</h2>
    <p class="muted">
      Καθεδρικοὶ καὶ μνημειακοὶ ναοὶ τῆς Ρωμηοσύνης μὲ ἰδιαιτέρα συμβολικὴ
      καὶ λατρευτικὴ θέσι στὸ ὀρθόδοξο φρόνημα.
    </p>
    <table class="mn-table">
      <thead><tr><th>Ὄνομα</th><th>Τοποθεσία</th><th>Αἰὼν ἱδρύσεως</th><th>Σημείωσις</th></tr></thead>
      <tbody>
        {naoi.map(n => (
          <tr class="mn-row">
            <td class="mn-title">{n.name}</td>
            <td class="mn-date">{n.location}</td>
            <td class="mn-date">{n.century}</td>
            <td class="muted">{n.note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mn-section">
    <h2>Σινᾶ</h2>
    <p class="muted">
      Ἡ θεοβάδιστος Μονὴ τοῦ Σινᾶ — αὐτόνομος, μὲ ἰδίαν ἀρχιεπισκοπήν —
      παραμένει ζωντανὸς τόπος προσκυνήσεως ἀπὸ τὸν ΣΤ΄ αἰῶνα συνεχῶς.
    </p>
    <table class="mn-table">
      <thead><tr><th>Ὄνομα</th><th>Τοποθεσία</th><th>Αἰὼν ἱδρύσεως</th><th>Σημείωσις</th></tr></thead>
      <tbody>
        {sina.map(s => (
          <tr class="mn-row">
            <td class="mn-title">{s.name}</td>
            <td class="mn-date">{s.location}</td>
            <td class="mn-date">{s.century}</td>
            <td class="muted">{s.note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <ShareButtons title="Εὑρετήριο Ναῶν καὶ Μοναστηριῶν — Ὀρθόδοξος Κόμβος" url={shareUrl} />
</BaseLayout>

<style>
  .mn-section { margin-top: 2.5rem; }
  .mn-section h2 {
    margin-top: 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .mn-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
  }
  .mn-table th, .mn-table td {
    text-align: left;
    padding: 0.65rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }
  .mn-table th {
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-muted, #6e6452);
  }
  .mn-rank {
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    color: var(--color-accent);
    font-weight: 600;
    width: 3rem;
  }
  .mn-date { white-space: nowrap; font-variant-numeric: tabular-nums; }
  .mn-title { font-weight: 500; }
</style>
