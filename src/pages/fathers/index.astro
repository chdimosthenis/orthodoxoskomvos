---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const fathers = (await getCollection('fathers'))
  .filter(f => f.data.language === lang && !f.data.draft)
  .sort((a, b) => a.data.century - b.data.century);
---

<BaseLayout title={t('all.fathers')}>
  <h1>{t('all.fathers')}</h1>
  <ul class="card-list">
    {fathers.length === 0 ? (
      <li class="muted">{t('no.entries')}</li>
    ) : fathers.map(f => (
      <li class="father-card">
        <h3>
          <a href={getLocalizedPath(`/fathers/${f.id}`, lang)} lang={f.data.language}>{f.data.name}</a>
        </h3>
        <p class="metadata">{f.data.century}{t('century.suffix')}</p>
        <p class="muted">{f.data.summary}</p>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .father-card {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .father-card:last-child { border-bottom: none; padding-bottom: 0; }
  .father-card h3 { margin: 0 0 0.35rem; font-size: 1.25rem; }
  .father-card h3 a { color: var(--color-text); border-bottom: none; }
  .father-card h3 a:hover { color: var(--color-accent); }
  .father-card p { margin: 0.4rem 0; }
</style>
