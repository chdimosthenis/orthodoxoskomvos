---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';

interface Props {
  slug: string;
  name: string;
  feastDay: string;
  category: 'martyr' | 'monastic' | 'hierarch' | 'apostle' | 'prophet' | 'other';
  language: 'el' | 'en';
  iconUrl?: string;
}

const { slug, name, feastDay, category, language, iconUrl } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const [month, day] = feastDay.split('-');
const dt = new Date(2024, Number(month) - 1, Number(day));
const dateStr = dt.toLocaleDateString(lang === 'el' ? 'el-GR' : 'en-GB', { day: 'numeric', month: 'long' });
---

<article class="card">
  {iconUrl && (
    <a class="thumb-link" href={getLocalizedPath(`/saints/${slug}`, lang)} aria-hidden="true" tabindex="-1">
      <img class="thumb" src={iconUrl} alt="" loading="lazy" decoding="async" />
    </a>
  )}
  <div class="card-body">
    <h3>
      <a href={getLocalizedPath(`/saints/${slug}`, lang)} lang={language}>{name}</a>
    </h3>
    <p class="metadata">
      {t('feastDay')}: {dateStr} · {t(`category.${category}` as UIKey)}
    </p>
  </div>
</article>

<style>
  .card {
    display: flex;
    gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .thumb-link {
    flex-shrink: 0;
    border-bottom: none;
  }
  .thumb {
    display: block;
    width: 56px;
    height: 56px;
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-radius: 2px;
  }
  .card-body { flex: 1; min-width: 0; }
  .card-body h3 {
    margin: 0 0 0.35rem;
    font-size: 1.2rem;
  }
  .card-body h3 a {
    color: var(--color-text);
    border-bottom: none;
  }
  .card-body h3 a:hover {
    color: var(--color-accent);
  }
</style>
