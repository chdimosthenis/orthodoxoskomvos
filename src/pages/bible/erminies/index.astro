---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const erminies = (await getCollection('erminies'))
  .filter(e => e.data.language === 'el' && !e.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by topic for navigation; counts in the section heading.
const topics = [
  { id: 'parable',    label: 'Παραβολές'   },
  { id: 'miracle',    label: 'Θαύματα'     },
  { id: 'discourse',  label: 'Ὁμιλίες'    },
  { id: 'narrative',  label: 'Ἀφηγηματικά' },
  { id: 'epistle',    label: 'Ἐπιστολές'   },
] as const;

const counts = Object.fromEntries(
  topics.map(t => [t.id, erminies.filter(e => e.data.topic === t.id).length])
) as Record<string, number>;
---

<BaseLayout title="Ἑρμηνεῖες — Καινὴ Διαθήκη">
  <p class="back-link"><a href="/bible">← Καινὴ Διαθήκη</a></p>
  <h1>Ἑρμηνεῖες</h1>
  <p class="muted">
    Ἑρμηνευτικὰ ἄρθρα γιὰ παραβολές, θαύματα, ὁμιλίες, ἀφηγηματικὰ καὶ ἐπιστολικὰ χωρία τῆς Καινῆς Διαθήκης.
    Σύντομες ἀναλύσεις μὲ νόημα, πατερικὲς προσεγγίσεις καὶ ἐφαρμογή.
  </p>

  {erminies.length === 0 ? (
    <p class="muted">Σύντομα.</p>
  ) : (
    <>
      <nav class="topic-toc" aria-label="Φίλτρο κατὰ εἶδος χωρίου">
        {topics.filter(t => counts[t.id] > 0).map(t => (
          <a href={`#topic-${t.id}`}>
            {t.label} <span class="muted">({counts[t.id]})</span>
          </a>
        ))}
      </nav>

      {topics.map(topic => {
        const inTopic = erminies.filter(e => e.data.topic === topic.id);
        if (inTopic.length === 0) return null;
        return (
          <section class="topic-section" id={`topic-${topic.id}`}>
            <h2>{topic.label}</h2>
            <ul class="erm-list">
              {inTopic.map(e => (
                <li class="erm-card">
                  <h3>
                    <a href={`/bible/erminies/${e.id}`}>{e.data.title}</a>
                  </h3>
                  <p class="erm-ref">{e.data.reference}</p>
                  <p class="muted">{e.data.description}</p>
                </li>
              ))}
            </ul>
          </section>
        );
      })}
    </>
  )}
</BaseLayout>

<style>
  .back-link { font-size: 0.9rem; margin-bottom: 1rem; }
  .topic-toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    padding: 0.85rem 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  .topic-toc a {
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .topic-toc a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .topic-section { margin-top: 2.25rem; scroll-margin-top: 4rem; }
  .topic-section h2 {
    margin-top: 0;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .erm-list {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: grid;
    gap: 1.5rem;
  }
  .erm-card {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .erm-card:last-child { border-bottom: none; padding-bottom: 0; }
  .erm-card h3 {
    margin: 0 0 0.25rem;
    font-size: 1.2rem;
  }
  .erm-card h3 a {
    color: var(--color-text);
    border-bottom: none;
  }
  .erm-card h3 a:hover { color: var(--color-accent); }
  .erm-ref {
    margin: 0 0 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gold);
    font-weight: 600;
  }
  .erm-card p.muted { margin: 0; }
</style>
