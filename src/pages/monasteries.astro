// --- 2. Μετέωρα (6 ἐνεργές) ---
const meteora = [
  { name: 'Μεγάλο Μετέωρο (Μεταμορφώσεως)', century: 'ΙΔ΄ αἰών (1340)', patron: 'Μεταμόρφωσις τοῦ Σωτῆρος', note: 'Ἡ μεγαλύτερη καὶ ἀρχαιότερη μονὴ τοῦ συμπλέγματος. Ἱδρυτὴς ὁ ὅσιος Ἀθανάσιος ὁ Μετεωρίτης.' },
  { name: 'Βαρλαάμ',                          century: 'ΙΔ΄ αἰών (1350)', patron: 'Ἅγιοι Πάντες',           note: 'Ἀνακαινίσθη τὸν ΙΣΤ΄ αἰ. ἀπὸ τοὺς ἀδελφοὺς Νεκτάριο καὶ Θεοφάνη Ἀψαρᾶ.' },
  { name: 'Ἁγίου Στεφάνου',                  century: 'ΙΔ΄ αἰών',         patron: 'Ἅγιος Χαράλαμπος',         note: 'Σήμερα γυναικεῖο μοναστήρι. Προσβάσιμο μὲ γέφυρα.' },
  { name: 'Ἁγίας Τριάδος',                    century: 'ΙΕ΄ αἰών (1476)',  patron: 'Ἁγία Τριάς',                note: 'Πρόσβασις διὰ 140 σκαλοπατιῶν λαξευμένων στὸν βράχο.' },
  { name: 'Ρουσσάνου',                         century: 'ΙΣΤ΄ αἰών (1545)', patron: 'Ἁγία Βαρβάρα',              note: 'Σήμερα γυναικεῖο μοναστήρι. Ἁγιογραφίες σχολῆς Θεοφάνους.' },
  { name: 'Ἁγίου Νικολάου Ἀναπαυσᾶ',          century: 'ΙΔ΄ αἰών',         patron: 'Ἅγιος Νικόλαος',            note: 'Τοιχογραφίες τοῦ Θεοφάνους Στρελίτζα τοῦ Κρητός (1527).' },
];

// --- 3. Μεγάλα προσκυνήματα τῆς Ἑλλάδος ---
const proskynemata = [
  { name: 'Παναγία Τήνου',                                location: 'Τῆνος, Κυκλάδες',       century: 'ΙΘ΄ αἰών (1823)', note: 'Εὕρεσις θαυματουργοῦ εἰκονίσματος Εὐαγγελισμοῦ τὸ 1822/3. Πανηγυρίζει 25 Μαρτίου καὶ 15 Αὐγούστου.' },
  { name: 'Παναγία Σουμελᾶ',                              location: 'Καστανιά Βερμίου',       century: 'Δ΄ αἰών (Πόντος)', note: 'Μεταφορὰ εἰκόνος ἀπὸ τὸν Πόντο μετὰ τὸ 1922. Σήμερον στὸ Βέρμιον.' },
  { name: 'Ἑκατονταπυλιανή',                              location: 'Παροικία Πάρου',         century: 'Δ΄ αἰών',          note: 'Ἀποδίδεται στὴν Ἁγία Ἑλένη. Μία τῶν ἀρχαιοτέρων χριστιανικῶν ἐκκλησιῶν τῆς Ἑλλάδος.' },
  { name: 'Πατμιάδα Ἁγίου Ἰωάννου τοῦ Θεολόγου',           location: 'Πάτμος, Δωδεκάνησα',     century: 'ΙΑ΄ αἰών (1088)',  note: 'Ἱδρυτὴς ὁ ὅσιος Χριστόδουλος. UNESCO. Σπήλαιον τῆς Ἀποκαλύψεως.' },
  { name: 'Μονὴ Ἁγίας Λαύρας',                            location: 'Καλάβρυτα Ἀχαΐας',       century: 'Ι΄ αἰών (961)',    note: 'Τόπος τῆς ἐνάρξεως τῆς Ἑλληνικῆς Ἐπαναστάσεως (25 Μαρτίου 1821).' },
  { name: 'Μονὴ Μέγα Σπηλαίου',                            location: 'Καλάβρυτα Ἀχαΐας',       century: 'Δ΄ αἰών',          note: 'Μία τῶν ἀρχαιοτέρων μονῶν τῆς Ἑλλάδος. Θαυματουργὴ εἰκόνα τῆς Παναγίας ἀπὸ κερὶ καὶ μαστίχα.' },
  { name: 'Μονὴ Ὁσίου Λουκᾶ',                              location: 'Στείρι Βοιωτίας',        century: 'ΙΑ΄ αἰών',         note: 'UNESCO. Ψηφιδωτὰ τῶν μέσων βυζαντινῶν χρόνων. Ὅσιος Λουκᾶς ὁ Στειριώτης.' },
  { name: 'Μονὴ Δαφνίου',                                  location: 'Χαϊδάρι Ἀττικῆς',         century: 'ΙΑ΄ αἰών',         note: 'UNESCO. Ψηφιδωτὰ μεσοβυζαντινῆς περιόδου. Παντοκράτωρ τοῦ τρούλλου.' },
  { name: 'Νέα Μονὴ Χίου',                                  location: 'Χίος',                    century: 'ΙΑ΄ αἰών (1042)',  note: 'UNESCO. Ἵδρυσις ἐπὶ Κωνσταντίνου Θ΄ Μονομάχου. Ψηφιδωτὰ μνημειώδους τέχνης.' },
  { name: 'Παναγία Παναχραντοῦ',                            location: 'Ἄνδρος, Κυκλάδες',         century: 'Ι΄ αἰών',          note: 'Ἵδρυσις ἐπὶ Νικηφόρου Φωκᾶ. Θαυματουργὴ εἰκόνα ἀποδιδομένη στὸν εὐαγγελιστὴ Λουκᾶ.' },
  { name: 'Μονὴ Ἁγίου Ἰωάννου Προδρόμου',                   location: 'Ἀκριτοχώρι Σερρῶν',       century: 'ΙΓ΄ αἰών',         note: 'Σταυροπηγιακὴ μονὴ ἐπὶ τοῦ ποταμοῦ Στρυμόνος.' },
  { name: 'Μονὴ Παναγίας Μαλεβῆς',                          location: 'Ἀρκαδία',                 century: 'Ι΄ αἰών',          note: 'Θαυματουργὴ εἰκόνα ἡ Μυροβλήτισσα. Ὑψόμετρον ~1.030 μ.' },
  { name: 'Μονὴ Παναγίας Προυσιωτίσσης',                    location: 'Προυσὸς Εὐρυτανίας',       century: 'Θ΄ αἰών',          note: 'Εἰκόνα τῆς Παναγίας Προυσιωτίσσης ἀποδιδομένη στὸν εὐαγγελιστὴ Λουκᾶ.' },
  { name: 'Μονὴ Ἁγίου Νεοφύτου',                             location: 'Πάφος, Κύπρος',           century: 'ΙΒ΄ αἰών (1159)',  note: 'Ἐγκλείστρα τοῦ ὁσίου Νεοφύτου. Σπάνιες τοιχογραφίες τοῦ ΙΒ΄ αἰ.' },
  { name: 'Μονὴ Κύκκου',                                     location: 'Τρόοδος, Κύπρος',         century: 'ΙΑ΄ αἰών (1080)',  note: 'Πλουσιοτέρα μονὴ τῆς Κύπρου. Εἰκόνα τῆς Παναγίας Κυκκωτίσσης.' },
];

// --- 4. Ἱστορικοὶ ναοί ---
const naoi = [
  { name: 'Ἁγία Σοφία Κωνσταντινουπόλεως',          location: 'Κωνσταντινούπολις',       century: 'ΣΤ΄ αἰών (537)',   note: 'Ἔργον Ἰουστινιανοῦ Α΄. Ἕδρα τοῦ Οἰκουμενικοῦ Πατριαρχείου ἕως τὸ 1453.' },
  { name: 'Παναγία τῶν Βλαχερνῶν',                    location: 'Κωνσταντινούπολις',       century: 'Ε΄ αἰών',          note: 'Τόπος τῆς ἀναμνήσεως τῆς Ἁγίας Σκέπης (1 Ὀκτωβρίου).' },
  { name: 'Ναὸς τῆς Ἀναστάσεως',                       location: 'Ἱεροσόλυμα',               century: 'Δ΄ αἰών',          note: 'Παναγιοτάφιον. Ἁγία Ἑλένη. Τελετὴ τοῦ Ἁγίου Φωτὸς κατὰ τὸ Πάσχα.' },
  { name: 'Ἁγία Σοφία Θεσσαλονίκης',                   location: 'Θεσσαλονίκη',              century: 'Η΄ αἰών',          note: 'UNESCO. Ψηφιδωτὰ τῆς Ἀναλήψεως. Ἱστορικὸς μητροπολιτικὸς ναός.' },
  { name: 'Ναὸς Ἁγίου Δημητρίου',                       location: 'Θεσσαλονίκη',              century: 'Ε΄ αἰών',          note: 'UNESCO. Πεντάκλιτος βασιλική. Τάφος τοῦ ἁγίου μυροβλήτου πολιούχου.' },
  { name: 'Μητρόπολις Ἀθηνῶν',                          location: 'Ἀθήνα',                     century: 'ΙΘ΄ αἰών (1862)',  note: 'Καθεδρικὸς Εὐαγγελισμοῦ τῆς Θεοτόκου. Ἕδρα τοῦ Ἀρχιεπισκόπου Ἀθηνῶν.' },
  { name: 'Ναὸς Ἁγίου Ἀνδρέου Πατρῶν',                  location: 'Πάτρα',                     century: 'Κ΄ αἰών (1908–74)', note: 'Μέγιστος ναὸς τῶν Βαλκανίων. Τάφος καὶ Τιμία Κάρα τοῦ ἁγίου ἀποστόλου Ἀνδρέου.' },
  { name: 'Ναὸς Ἁγίου Σπυρίδωνος',                       location: 'Κέρκυρα',                   century: 'ΙΣΤ΄ αἰών (1590)', note: 'Σκήνωμα τοῦ ἁγίου Σπυρίδωνος. Λιτανεῖες τῆς πόλεως 4 φορὲς τὸν χρόνο.' },
  { name: 'Ναὸς Ἁγίου Διονυσίου',                        location: 'Ζάκυνθος',                  century: 'ΙΘ΄ αἰών (1893)',  note: 'Σκήνωμα τοῦ ἁγίου Διονυσίου, πολιούχου τῆς νήσου.' },
  { name: 'Καθεδρικὸς Ἁγίου Νικολάου',                  location: 'Ἑρμούπολις, Σύρος',          century: 'ΙΘ΄ αἰών (1870)',  note: 'Νεοκλασικὸς καθεδρικὸς τῆς Ἑρμουπόλεως. Ἕδρα τῆς Μητροπόλεως Σύρου.' },
